# ─── Backend (FastAPI / quant/) ──────────────────────────────────────────────

# Hyperliquid credentials
# Vault address to monitor / trade from
HYPERLIQUID_VAULT_ADDRESS=0xYourVaultAddress
# Agent wallet that signs transactions on behalf of the vault
HYPERLIQUID_AGENT_ADDRESS=0xYourAgentWalletAddress
HYPERLIQUID_AGENT_PRIVATE_KEY=0xYourAgentPrivateKey
# "mainnet" or "testnet"
HYPERLIQUID_NETWORK=mainnet

# Database (SQLite path, relative to quant/)
DATABASE_URL=sqlite:///./data/hypertrade.db

# Telegram alerts
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff-1234567890
TELEGRAM_CHAT_ID=-1001234567890

# Dashboard deep-link base URL (used in Telegram alert messages)
# Set to wherever the dashboard is accessible
DASHBOARD_URL=https://your-dashboard.vercel.app

# ─── LLM provider for news classification ────────────────────────────────────
# Supported: claude (default), gemini, deepseek, openai
LLM_PROVIDER=claude

# Override the model (optional — each provider has a sensible default)
# claude   → claude-haiku-4-5-20251001
# gemini   → gemini-2.0-flash
# deepseek → deepseek-chat
# openai   → gpt-4o-mini
# LLM_MODEL=

# API keys — only the key for your chosen LLM_PROVIDER is required
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
DEEPSEEK_API_KEY=sk-...
OPENAI_API_KEY=sk-...

# ─── Frontend (Next.js / dashboard/) — set these in dashboard/.env.local ──────

# URL of the running FastAPI backend (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL of the FastAPI backend
NEXT_PUBLIC_WS_URL=ws://localhost:8000
