# Copy this file to `.env` before running `docker compose up`.
# For production, use `deploy/.env.production.example` as the template instead.

# Published host ports
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Frontend browser-side endpoints
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SIGNAL_WS_URL=ws://localhost:8000/ws/signals

# Backend dev defaults
ENABLE_MOCK_SIGNALS=true
LOG_LEVEL=INFO
LOG_FILE=./backend/logs/backend.log
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend file watching inside Docker bind mounts
WATCHPACK_POLLING=true

# Telegram forwarding is disabled by default.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
